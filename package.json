{
  "name": "knox-stringing",
  "private": true,
  "repository": "github:bknox83/knoxstringing-website",
  "homepage": "https://knoxstringing.com",
  "scripts": {
    "build": "npm run minify:css && npm run minify:js",
    "minify:css": "cleancss -o assets/css/styles.min.css assets/css/styles.css",
    "minify:js": "terser assets/js/script.js -o assets/js/script.min.js -c -m"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.0",
    "terser": "^5.36.0"
  }
}
